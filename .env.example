# 제품문의 메일 발송 — 아래 둘 중 하나만 설정하면 됨

# [방법 1] Resend (권장, 앱 비밀번호 불필요)
# https://resend.com 에서 가입 후 API 키 발급, 발신 도메인 설정
RESEND_API_KEY=
RESEND_FROM=TNQ 제품문의 <onboarding@resend.dev>

# [방법 2] Gmail SMTP (RESEND_API_KEY 없을 때 사용, 앱 비밀번호 필요)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=wy.solution.soma@gmail.com
SMTP_PASSWORD=
SMTP_FROM=wy.solution.soma@gmail.com

# reCAPTCHA v2 (선택) - 설정 시 폼에 reCAPTCHA 표시 및 검증
# https://www.google.com/recaptcha/admin 에서 사이트 키/비밀키 발급
# NEXT_PUBLIC_ 은 브라우저에 노출되므로 사이트 키만 사용
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
